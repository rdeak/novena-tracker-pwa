                  "role": "S",
                  "text": "i ispuni me svojom ljubavlju."
                },
                {
                  "role": "P",
                  "text": "Bezgrešno Srce Marijino,"
                },
                {
                  "role": "S",
                  "text": "budi naše utočište, zaštita i mjesto pripreme za borbu s nečistim dusima. Amen."
                }
