  "library": [
    {
      "id": "weekly-rosaries",
      "title": "Krunice — Tjedni molitveni ciklus",
      "type": "weekly",
      "prayers": [
        {
          "day": "Ponedjeljak",
          "dayIndex": 1,
          "title": "Krunica poniznosti",
          "theme": "Poniznost",
          "sections": [
            {
              "type": "uvod",
              "repeat": 1,
              "verses": [
                "Oče naš",
                "Zdravo Marijo",
                "Vjerovanje"
              ]
            },
            {
              "type": "velika_zrnca",
              "repeat": 1,
              "verses": [
                {
                  "role": "P",
                  "text": "Slavim te, Oče, Gospodaru neba i zemlje što si ovo sakrio od mudrih i umnih,"
                },
                {
                  "role": "S",
                  "text": "a objavio malenima."
                }
              ],
              "reference": "Mt 11,25"
            },
            {
              "type": "mala_zrnca",
              "repeat": 10,
              "verses": [
                {
                  "role": "P",
                  "text": "Isuse blaga i ponizna Srca –"
                },
                {
                  "role": "S",
                  "text": "učini srca naša po Srcu svome!"
                }
              ]
            },
            {
              "type": "završetak",
              "repeat": 1,
              "verses": [
                "Dođite k meni svi koji ste izmoreni i opterećeni",
                "i ja ću vas odmoriti.",
                "Uzmite jaram moj na sebe, učite se od mene jer sam krotka i ponizna srca",
                "i naći ćete spokoj dušama svojim.",
                "Uistinu, jaram je moj sladak",
                "i breme moje lako."
              ],
              "reference": "Mt 11,28-30"
            }
          ]
        },
        {
          "day": "Utorak",
          "dayIndex": 2,
          "title": "Krunica anđelima čuvarima",
