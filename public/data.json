            },
            {
              "type": "dodatna_molitva",
              "repeat": null,
              "verses": [
                "Sveti Mihaele arkanđele, brani nas u boju; protiv pakosti i zasjeda đavolskih budi nam zaklon! Neka mu Bog zapovijedi, ponizno molimo, i ti, vojvodo vojske nebeske, Sotonu i druge zle duhove koji svijetom obilaze na propast duša božanskom jakošću u pakao protjeraj! Amen."
              ],
              "title": "Molitva svetom Mihaelu arkanđelu",
              "attribution": "Papa Lav XIII."
            }
          ]
