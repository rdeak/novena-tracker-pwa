              "verses": [
                {
                  "role": "S",
                  "text": "Sveti Bože, Sveti Jaki Bože, Sveti Besmrtni Bože, smiluj se nama i cijelome svijetu."
                }
              ]
            },
            {
              "type": "dodatna_molitva",
              "repeat": null,
              "verses": [
                "Isuse, ja se uzdam u Tebe! O Krvi i Vodo koja si potekla iz probodenog Srca Isusova kao izvor milosrđa za nas, uzdamo se u Te!"
              ]
