            },
            {
              "type": "dodatna_molitva",
              "repeat": null,
              "verses": [
                "Sveti Josipe, čuvaru djevica, u tvojoj čistoći i predanju Bogu štitio si nekad Svetu obitelj, a sada si zaštitnik cijele Crkve. Pouzdajemo se u te i molimo pomoć u borbi za čistoću srca. Amen."
              ],
              "title": "Molitva svetom Josipu"
