              "type": "završetak",
              "repeat": null,
              "verses": [
                {
                  "role": "S",
                  "text": "Vječni Oče, prikazujemo Ti Predragocjenu Krv Isusa Krista kao zadovoljštinu za svoje grijehe, na utjehu duša u čistilištu i za potrebe svete Crkve. Amen.",
                  "repeat": 1
                },
