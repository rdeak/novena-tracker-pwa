---
import Layout from '@/layouts/Layout.astro';
import Counter from '@/components/Counter';
---

<Layout title="Astro Starter | Static, React, Tailwind">
	<main class="max-w-4xl mx-auto px-6 py-12 md:py-24">
		<header class="mb-16 text-center">
			<h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-4 bg-linear-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
				Astro Starter Template
			</h1>
			<p class="text-xl text-gray-600 max-w-2xl mx-auto">
				Fast, static-first website with minimal React islands, powered by Tailwind CSS 4 and TypeScript.
			</p>
		</header>

		<section class="grid md:grid-cols-2 gap-8 items-center">
			<div class="space-y-6">
				<div class="p-6 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
					<h2 class="text-xl font-bold mb-2 flex items-center gap-2 text-blue-700">
						🚀 Ship Static
					</h2>
					<p class="text-gray-600">
						Zero-JavaScript by default. Every page is pre-rendered for maximum performance and SEO.
					</p>
				</div>
				
				<div class="p-6 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
					<h2 class="text-xl font-bold mb-2 flex items-center gap-2 text-indigo-700">
						⚛️ Selective Hydration
					</h2>
					<p class="text-gray-600">
						Only load React when you need it. Use interactive islands for complex UI parts.
					</p>
				</div>

				<div class="p-6 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
					<h2 class="text-xl font-bold mb-2 flex items-center gap-2 text-cyan-700">
						🎨 Tailwind 4
					</h2>
					<p class="text-gray-600">
						Modern styling workflow with the latest Tailwind CSS version.
					</p>
				</div>
			</div>

			<div class="flex justify-center">
				<Counter client:visible />
			</div>
		</section>

		<footer class="mt-24 pt-8 border-t border-gray-200 text-center text-gray-500 text-sm">
			<p>© {new Date().getFullYear()} — Built with <a href="https://astro.build" class="hover:text-blue-600 underline underline-offset-4 transition-colors">Astro</a></p>
		</footer>
	</main>
</Layout>
