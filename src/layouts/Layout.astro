---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A modern Astro + React starter for GitHub Pages" } = Astro.props;

// For SEO and relative links
const base = import.meta.env.BASE_URL;
const siteUrl = Astro.site?.toString() || 'https://username.github.io';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    
    <link rel="canonical" href={canonicalURL} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="p-6 border-b bg-white">
      <nav class="max-w-4xl mx-auto flex justify-between items-center">
        <a href={base} class="text-xl font-bold tracking-tight">Astro Starter</a>
        <ul class="flex gap-4">
          <li><a href={base} class="hover:text-blue-600">Home</a></li>
          <li><a href="https://github.com/rdeak/novena-tracker-pwa" class="hover:text-blue-600">GitHub</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-grow max-w-4xl mx-auto w-full p-6">
      <slot />
    </main>

    <footer class="p-6 border-t bg-white text-center text-sm text-slate-500">
      &copy; {new Date().getFullYear()} Astro Starter. Built with Astro & Tailwind CSS.
    </footer>
  </body>
</html>
